generator client {
  provider = "prisma-client"
  output   = "../lib/prisma-client"
}

datasource db {
  provider = "postgresql"
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model conversation {
  id                                 String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                              String     @default("Private Chat") @db.VarChar(150)
  user1_id                           String     @db.Uuid
  user2_id                           String     @db.Uuid
  is_locked                          Boolean    @default(false)
  created_at                         DateTime   @default(now()) @db.Timestamp(6)
  updated_at                         DateTime   @default(now()) @db.Timestamp(6)
  users_conversation_user1_idTousers users      @relation("conversation_user1_idTousers", fields: [user1_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users_conversation_user2_idTousers users      @relation("conversation_user2_idTousers", fields: [user2_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  messages                           messages[]
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model messages {
  id                  String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversation_id     String       @db.Uuid
  sender_id           String       @db.Uuid
  message_type        String       @default("text") @db.VarChar(20)
  content             String
  is_read             Boolean      @default(false)
  sent_at             DateTime     @default(now()) @db.Timestamp(6)
  edited_at           DateTime?    @db.Timestamp(6)
  deleted_at          DateTime?    @db.Timestamp(6)
  reply_to_message_id String?      @db.Uuid
  conversation        conversation @relation(fields: [conversation_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  users               users        @relation(fields: [sender_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
  reply_to            messages?    @relation("MessageReply", fields: [reply_to_message_id], references: [id], onDelete: SetNull)
  replies             messages[]   @relation("MessageReply")

  message_hidden     message_hidden[]
  message_reactions  message_reactions[]

  @@index([conversation_id], map: "idx_messages_conversation_id")
  @@index([sender_id], map: "idx_messages_sender_id")
  @@index([sent_at], map: "idx_messages_sent_at")
}

/// حذف «من عندي فقط»: المستخدم يخفي الرسالة من واجهته فقط
model message_hidden {
  user_id    String   @db.Uuid
  message_id String   @db.Uuid
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  messages   messages @relation(fields: [message_id], references: [id], onDelete: Cascade)

  @@id([user_id, message_id])
  @@index([user_id], map: "idx_message_hidden_user_id")
  @@index([message_id], map: "idx_message_hidden_message_id")
}

/// تفاعلات الرسائل (مثل ردود الفعل السريعة)
model message_reactions {
  message_id String   @db.Uuid
  user_id    String   @db.Uuid
  emoji      String   @db.VarChar(20)
  messages   messages @relation(fields: [message_id], references: [id], onDelete: Cascade)
  users      users    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@id([message_id, user_id])
  @@index([message_id], map: "idx_message_reactions_message_id")
}

/// This table contains check constraints and requires additional setup for migrations. Visit https://pris.ly/d/check-constraints for more info.
model users {
  id                                        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  full_name                                 String         @db.VarChar(150)
  username                                  String?        @unique @db.VarChar(100)
  email                                     String?        @unique @db.VarChar(150)
  password_hash                             String
  avatar_url                                String?        @db.VarChar(512)
  is_active                                 Boolean        @default(true)
  is_admin                                  Boolean        @default(false)
  last_seen                                 DateTime?      @db.Timestamp(6)
  created_at                                DateTime       @default(now()) @db.Timestamp(6)
  updated_at                                DateTime       @default(now()) @db.Timestamp(6)
  conversation_conversation_user1_idTousers conversation[] @relation("conversation_user1_idTousers")
  conversation_conversation_user2_idTousers conversation[] @relation("conversation_user2_idTousers")
  messages                                  messages[]
  message_hidden                             message_hidden[]
  message_reactions                          message_reactions[]
}
